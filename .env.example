# Google Ads API credentials
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CREDENTIALS_PATH=./credentials.json

# Auth type: "oauth" (default) or "service_account"
GOOGLE_ADS_AUTH_TYPE=oauth

# Required for MCC accounts — the manager account ID
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Service account only — email to impersonate
GOOGLE_ADS_IMPERSONATION_EMAIL=

# Enable write tools (pause/enable campaigns, update budgets, etc.)
# GOOGLE_ADS_ENABLE_MUTATIONS=false
