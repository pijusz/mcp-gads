{
  "name": "mcp-gads",
  "version": "0.1.5",
  "description": "Google Ads MCP server — query campaigns, keywords, assets & more via natural language",
  "type": "module",
  "bin": {
    "mcp-gads": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build src/index.ts --compile --outfile=mcp-gads",
    "build:npm": "bun build src/index.ts --bundle --target node --outfile dist/index.js && node -e \"const f='dist/index.js';require('fs').writeFileSync(f,require('fs').readFileSync(f,'utf8').replace('#!/usr/bin/env bun','#!/usr/bin/env node'))\"",
    "prepublishOnly": "bun run build:npm",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "setup": "bun run src/auth/setup.ts",
    "inspect": "bunx @modelcontextprotocol/inspector bun src/index.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "check": "biome check --write ."
  },
  "keywords": [
    "mcp",
    "google-ads",
    "google-ads-api",
    "ai",
    "claude",
    "model-context-protocol",
    "bun"
  ],
  "author": "pijusz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pijusz/mcp-gads.git"
  },
  "homepage": "https://github.com/pijusz/mcp-gads#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "google-auth-library": "^9.15.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "^1.2.9",
    "typescript": "^5.8.3"
  }
}
